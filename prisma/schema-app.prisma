generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/@prisma/client-app"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String       @id @default(uuid())
  email                      String       @unique
  isActive                   Boolean      @default(true)
  createdAt                  DateTime     @default(now())
  welcomeEmailSent           Boolean      @default(false)
  notificationBillingUpdates Boolean      @default(true)
  notificationUsageAlerts    Boolean      @default(true)
  lastActiveAt               DateTime?
  emailVerified              Boolean      @default(false)
  image                      String?
  name                       String?
  updatedAt                  DateTime     @default(now()) @updatedAt
  role                       String       @default("user")
  conversions                Conversion[]
  memberships                Membership[]
  webhookLogs                WebhookLog[]
  accounts                   Account[]
  sessions                   Session[]
}

model Organization {
  id                     String                  @id @default(uuid())
  name                   String
  planId                 String
  stripeCustomerId       String?                 @unique
  lemonSqueezyCustomerId String?                 @unique
  paystackCustomerCode   String?                 @unique
  paddleCustomerId       String?
  paddleSubscriptionId   String?
  ipWhitelist            String[]                @default([])
  planStartedAt          DateTime?
  billingInterval        String                  @default("month")
  createdAt              DateTime                @default(now())
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  conversions            Conversion[]
  financialDocuments     FinancialDocument[]
  integrations           IntegrationConnection[]
  invites                Invite[]
  memberships            Membership[]
  plan                   Plan                    @relation(fields: [planId], references: [id])
  templates              Template[]
  usage                  Usage[]
  vendors                VendorIdentity[]
  webhookLogs            WebhookLog[]
}

model Membership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           String       @default("MEMBER")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model ApiKey {
  id             String       @id @default(uuid())
  userId         String
  keyHash        String       @unique
  type           String
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  organizationId String
  expiresAt      DateTime?
  hint           String?
  name           String       @default("Default Key")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([organizationId])
}

model Plan {
  id                          String         @id @default(uuid())
  name                        String         @unique
  limit                       Int
  stripePriceId               String?        @unique
  lemonSqueezyVariantId       String?        @unique
  paystackPlanCode            String?        @unique
  priceNgn                    Int            @default(0)
  priceUsd                    Int            @default(0)
  allowIpWhitelisting         Boolean        @default(false)
  allowCustomHeaders          Boolean        @default(false)
  allowWebhooks               Boolean        @default(false)
  lemonSqueezyVariantIdAnnual String?        @unique
  maxFileSize                 Int            @default(10485760)
  paystackPlanCodeAnnual      String?        @unique
  priceNgnAnnual              Int            @default(0)
  priceUsdAnnual              Int            @default(0)
  rateLimitPerMin             Int            @default(10)
  retentionDays               Int            @default(7)
  allowAi                     Boolean        @default(false)
  allowTailwind               Boolean        @default(false)
  paddlePriceId               String?
  paddlePriceIdAnnual         String?
  allowGhostMode              Boolean        @default(false)
  aiLimit                     Int            @default(0)
  aiTemplateLimit             Int            @default(0)
  maxSeats                    Int            @default(1)
  organizations               Organization[]
}

model Usage {
  id              String       @id @default(uuid())
  month           Int
  year            Int
  count           Int          @default(0)
  createdAt       DateTime     @default(now())
  aiCount         Int          @default(0)
  aiTemplateCount Int          @default(0)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, month, year])
  @@index([organizationId, month, year])
}

model Conversion {
  id             String       @id @default(uuid())
  userId         String
  url            String?
  htmlLength     Int?
  success        Boolean      @default(false)
  errorMsg       String?
  duration       Int
  createdAt      DateTime     @default(now())
  status         String       @default("PENDING")
  retentionDays  Int          @default(7)
  aiMetadata     Json?
  creditsUsed    Int          @default(1)
  fileSize       Int?
  htmlBody       String?
  isGhostMode    Boolean      @default(false)
  isTestMode     Boolean      @default(false)
  metadata       Json?
  s3Key          String?
  webhookUrl     String?
  organizationId String
  idempotencyKey String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  webhookLogs    WebhookLog[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([idempotencyKey])
}

model IpUsage {
  id        String   @id @default(uuid())
  ip        String
  month     Int
  year      Int
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ip, month, year])
  @@index([ip, month, year])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  type        String
  createdAt   DateTime  @default(now())
  payload     Json
  url         String?
  attempts    Int       @default(0)
  lastAttempt DateTime?
  nextRetry   DateTime?
  status      String    @default("pending")
  errorMsg    String?

  @@index([status, nextRetry])
}

model WebhookLog {
  id             String       @id @default(uuid())
  conversionId   String
  userId         String
  url            String
  payload        Json
  statusCode     Int?
  responseBody   String?
  duration       Int?
  createdAt      DateTime     @default(now())
  organizationId String
  conversion     Conversion   @relation(fields: [conversionId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([conversionId])
  @@index([userId])
  @@index([organizationId])
}

model Template {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  html           String
  css            String?
  variables      String[]     @default([])
  prompt         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Invite {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("MEMBER")
  token          String       @unique
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

model VendorIdentity {
  id             String       @id @default(uuid())
  organizationId String
  originalName   String
  normalizedName String
  category       String?
  confidence     Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, normalizedName])
  @@index([organizationId])
}

model Integration {
  id          String                  @id
  name        String
  category    String
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  connections IntegrationConnection[]
}

model IntegrationConnection {
  id             String       @id @default(uuid())
  organizationId String
  integrationId  String
  tenantId       String?
  tenantName     String?
  accessToken    String
  refreshToken   String?
  idToken        String?
  expiresAt      DateTime?
  status         String       @default("ACTIVE")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  integration    Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, integrationId])
  @@index([organizationId])
}

model FinancialDocument {
  id             String              @id @default(uuid())
  organizationId String
  type           String              @default("BILL")
  status         String              @default("PENDING")
  vendorName     String?
  vendorEmail    String?
  invoiceNumber  String?
  currency       String              @default("USD")
  totalAmount    Decimal             @db.Decimal(20, 4)
  taxAmount      Decimal?            @db.Decimal(20, 4)
  date           DateTime?
  dueDate        DateTime?
  s3Key          String?
  metadata       Json?
  externalId     String?
  externalUrl    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  isTestMode     Boolean             @default(false)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineItems      FinancialLineItem[]

  @@index([organizationId])
  @@index([status])
  @@index([type])
}

model FinancialLineItem {
  id          String            @id @default(uuid())
  documentId  String
  description String
  quantity    Decimal           @default(1) @db.Decimal(20, 4)
  unitPrice   Decimal           @db.Decimal(20, 4)
  totalPrice  Decimal           @db.Decimal(20, 4)
  accountCode String?
  taxCode     String?
  document    FinancialDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}
