generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-app"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String       @id @default(uuid())
  email                      String       @unique
  isActive                   Boolean      @default(true)
  createdAt                  DateTime     @default(now())
  clerkId                    String?      @unique
  welcomeEmailSent           Boolean      @default(false)
  notificationBillingUpdates Boolean      @default(true)
  notificationUsageAlerts    Boolean      @default(true)
  lastActiveAt               DateTime?
  name                       String?
  image                      String?
  conversions                Conversion[]
  memberships                Membership[]
  webhookLogs                WebhookLog[]
}

model Organization {
  id                     String       @id @default(uuid())
  name                   String
  planId                 String
  stripeCustomerId       String?      @unique
  lemonSqueezyCustomerId String?      @unique
  paystackCustomerCode   String?      @unique
  paddleCustomerId       String?
  paddleSubscriptionId   String?
  clerkOrgId             String?      @unique
  ipWhitelist            String[]     @default([])
  planStartedAt          DateTime?
  billingInterval        String       @default("month")
  createdAt              DateTime     @default(now())
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  conversions            Conversion[]
  invites                Invite[]
  memberships            Membership[]
  plan                   Plan         @relation(fields: [planId], references: [id])
  templates              Template[]
  usage                  Usage[]
  webhookLogs            WebhookLog[]
  financialDocuments     FinancialDocument[]
  vendorIdentities       VendorIdentity[]
}

model Membership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           String       @default("MEMBER")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model ApiKey {
  id             String       @id @default(uuid())
  userId         String
  keyHash        String       @unique
  type           String
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  organizationId String
  expiresAt      DateTime?
  hint           String?
  name           String       @default("Default Key")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([organizationId])
}

model Plan {
  id                          String         @id @default(uuid())
  name                        String         @unique
  limit                       Int
  stripePriceId               String?        @unique
  lemonSqueezyVariantId       String?        @unique
  paystackPlanCode            String?        @unique
  priceNgn                    Int            @default(0)
  priceUsd                    Int            @default(0)
  allowIpWhitelisting         Boolean        @default(false)
  allowCustomHeaders          Boolean        @default(false)
  allowWebhooks               Boolean        @default(false)
  lemonSqueezyVariantIdAnnual String?        @unique
  paddlePriceId               String?
  paddlePriceIdAnnual         String?
  maxFileSize                 Int            @default(10485760)
  paystackPlanCodeAnnual      String?        @unique
  priceNgnAnnual              Int            @default(0)
  priceUsdAnnual              Int            @default(0)
  rateLimitPerMin             Int            @default(10)
  retentionDays               Int            @default(7)
  allowAi                     Boolean        @default(false)
  allowTailwind               Boolean        @default(false)
  allowGhostMode              Boolean        @default(false)
  aiLimit                     Int            @default(0)
  aiTemplateLimit             Int            @default(0)
  maxSeats                    Int            @default(1)
  organizations               Organization[]
}

model Usage {
  id              String       @id @default(uuid())
  month           Int
  year            Int
  count           Int          @default(0)
  createdAt       DateTime     @default(now())
  aiCount         Int          @default(0)
  aiTemplateCount Int          @default(0)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, month, year])
  @@index([organizationId, month, year])
}

model Conversion {
  id             String       @id @default(uuid())
  userId         String
  url            String?
  htmlLength     Int?
  success        Boolean      @default(false)
  errorMsg       String?
  duration       Int
  createdAt      DateTime     @default(now())
  status         String       @default("PENDING")
  retentionDays  Int          @default(7)
  isTestMode     Boolean      @default(false)
  aiMetadata     Json?
  s3Key          String?
  metadata       Json?
  creditsUsed    Int          @default(1)
  fileSize       Int?
  htmlBody       String?
  isGhostMode    Boolean      @default(false)
  webhookUrl     String?
  organizationId String
  idempotencyKey String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  webhookLogs    WebhookLog[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([idempotencyKey])
}


model IpUsage {
  id        String   @id @default(uuid())
  ip        String
  month     Int
  year      Int
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ip, month, year])
  @@index([ip, month, year])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  type        String
  createdAt   DateTime  @default(now())
  payload     Json
  url         String?
  attempts    Int       @default(0)
  lastAttempt DateTime?
  nextRetry   DateTime?
  status      String    @default("pending")
  errorMsg    String?

  @@index([status, nextRetry])
}

model WebhookLog {
  id             String       @id @default(uuid())
  conversionId   String
  userId         String
  url            String
  payload        Json
  statusCode     Int?
  responseBody   String?
  duration       Int?
  createdAt      DateTime     @default(now())
  organizationId String
  conversion     Conversion   @relation(fields: [conversionId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([conversionId])
  @@index([userId])
  @@index([organizationId])
}

model Template {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  html           String
  css            String?
  variables      String[]     @default([])
  prompt         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Invite {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("MEMBER")
  token          String       @unique
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

model FinancialDocument {
  id             String       @id @default(uuid())
  organizationId String
  status         String       @default("PENDING")
  vendorName     String?
  totalAmount    Float        @default(0)
  isTestMode     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model VendorIdentity {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  website        String?
  organization   Organization @relation(fields: [organizationId], references: [id])
}
